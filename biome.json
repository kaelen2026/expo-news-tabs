{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.expo",
      "!**/.next",
      "!**/.turbo",
      "!**/dist",
      "!**/build",
      "!apps/mobile/android",
      "!apps/mobile/ios",
      "!**/expo-env.d.ts",
      "!**/next-env.d.ts",
      "!apps/web/app/globals.css",
      "!**/pnpm-lock.yaml",
      "!**/package-lock.json",
      "!packages/db/migrations"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  }
}
