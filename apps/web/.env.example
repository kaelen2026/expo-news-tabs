# --- API connection ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- better-auth ---
# Server-side: where better-auth is mounted (same origin as the web app)
BETTER_AUTH_URL=http://localhost:3000
# Client-side mirror used by lib/auth-client.ts
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
# Long random string. Generate with: openssl rand -base64 32
# MUST be byte-identical to apps/api's BETTER_AUTH_SECRET — sessions are
# signed with it, so a mismatch silently breaks cross-app login. The
# shared `auth-config` package refuses to start in production with the
# dev fallback.
BETTER_AUTH_SECRET=

# --- Database (MUST be the same as apps/api — sessions live here) ---
DATABASE_URL=postgresql://app:app@localhost:5432/app

# --- Social providers (optional; leave empty to disable) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
