# Connection string to the Postgres instance from docker-compose. Must
# point at the SAME database as apps/web — sessions live there.
DATABASE_URL=postgresql://app:app@localhost:5432/app

# Port the Hono server listens on (defaults to 3001).
PORT=3001

# Where this API advertises its own better-auth endpoints (defaults to
# http://localhost:3001 in dev). The mobile app talks to /auth/* here.
API_AUTH_URL=http://localhost:3001

# Browser origin for apps/web — added to trustedOrigins and to the CORS
# allow-list. Defaults to http://localhost:3000 in dev.
WEB_ORIGIN=http://localhost:3000

# Long random string. Generate with: openssl rand -base64 32
# MUST be byte-identical to apps/web's BETTER_AUTH_SECRET — better-auth
# signs sessions with it, so a mismatch means tokens minted by one app
# fail to verify on the other. Leaving this empty in development is
# allowed (a dev fallback is used); production refuses to start without it.
BETTER_AUTH_SECRET=
