{
  "expo": {
    "name": "News Tabs",
    "slug": "expo-news-tabs",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "newstabs",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jialin2023.exponewstabs"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f7f2e8"
      },
      "package": "com.jialin2023.exponewstabs"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
